{
  "name": "@levu304/excelrs",
  "version": "0.2.1",
  "description": "Native XLSX spreadsheet library for Node.js (Rust port of exceljs)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "packageManager": "pnpm@9.15.4",
  "napi": {
    "binaryName": "excelrs",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --js native.js",
    "build:release": "napi build --platform --release --js native.js",
    "test": "vitest run",
    "format": "cargo fmt --",
    "lint": "cargo clippy -- -D warnings"
  },
  "optionalDependencies": {
    "@levu304/excelrs-darwin-arm64": "0.2.1",
    "@levu304/excelrs-linux-x64-gnu": "0.2.1",
    "@levu304/excelrs-win32-x64-msvc": "0.2.1"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "vitest": "^4.1.9",
    "typescript": "^5.8.0",
    "exceljs": "^4.4.0"
  }
}
