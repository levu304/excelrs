{
  "name": "@levu304/excelrs",
  "version": "0.13.0",
  "description": "Native XLSX spreadsheet library for Node.js (Rust port of exceljs)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT OR Apache-2.0",
  "packageManager": "pnpm@9.15.4",
  "napi": {
    "binaryName": "excelrs",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --js native.js --dts native.d.ts",
    "build:release": "napi build --platform --release --js native.js --dts native.d.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "cargo fmt --",
    "lint": "cargo clippy -- -D warnings",
    "lint:js": "biome lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@napi-rs/cli": "^3.2.0",
    "@types/node": "^26.1.1",
    "exceljs": "^4.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
